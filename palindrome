import java.util.*;


public class palindrome
{
    
    
	public static void main(String[] args) {
		
	String str = "racecar";
	String str1 = new StringBuilder(str)
	              .reverse()
	              .toString();
	 if(str.equals(str1))
	 {
	     System.out.println("it is a palindrome");
	 }
